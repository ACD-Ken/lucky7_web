# Server
NODE_ENV=development
PORT=3000

# Anthropic AI — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from Supabase dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_KEY=<service-role-key>

# PostgreSQL direct connection — get from Supabase → Settings → Database
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Firebase FCM — get from Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=<project-id>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-<id>@<project-id>.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-byte-hex-string>

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Gmail — get from Google Cloud Console → OAuth 2.0 credentials
# Requires Gmail API enabled + OAuth consent screen configured
GMAIL_CLIENT_ID=<client-id>.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-<secret>
GMAIL_REFRESH_TOKEN=<refresh-token>
GMAIL_FROM_EMAIL=your-email@gmail.com
